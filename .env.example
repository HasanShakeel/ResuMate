# =============================================================================
# Professional Resume Builder — Environment Variables
# =============================================================================

# --- Application ---
APP_NAME="Professional Resume Builder"
APP_VERSION="1.0.0"
DEBUG=true
HOST=0.0.0.0
PORT=8000

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./data/resume_builder.db

# --- Security ---
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# --- PDF Engine ---
# Options: playwright, weasyprint
PDF_ENGINE=playwright

# --- Storage ---
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports
MAX_UPLOAD_SIZE_MB=5

# --- Optional: Future Auth ---
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=60
